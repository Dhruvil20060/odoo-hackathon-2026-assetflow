<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Security Category Definition -->
        <record id="module_category_assetflow" model="ir.module.category">
            <key>assetflow</key>
            <field name="name">AssetFlow Management</field>
            <field name="sequence">100</field>
        </record>

        <!-- Base Employee Group -->
        <record id="group_employee" model="res.groups">
            <field name="name">Employee</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Base Employee Group. Can view assets allocated to them, book resources, and raise maintenance requests.</field>
        </record>

        <!-- Department Head Group -->
        <record id="group_dept_head" model="res.groups">
            <field name="name">Department Head</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_employee'))]"/>
            <field name="comment">Department Head Group. Can view assets allocated to department, approve transfers within department, and book resources on behalf of department.</field>
        </record>

        <!-- Asset Manager Group -->
        <record id="group_asset_manager" model="res.groups">
            <field name="name">Asset Manager</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_dept_head'))]"/>
            <field name="comment">Asset Manager Group. Can register assets, allocate assets, and approve transfers/returns/maintenance requests.</field>
        </record>

        <!-- Admin Group -->
        <record id="group_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_asset_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Admin Group. Manages departments, asset categories, audit cycles, and employee directories.</field>
        </record>
    </data>
</odoo>
